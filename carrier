#!/bin/sh

# Load env file from same directory as script
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="$SCRIPT_DIR/.env"

if [ ! -f "$ENV_FILE" ]; then
    echo "ERROR: .env file not found at $ENV_FILE"
    echo "Create it with:"
    echo '  U5G_HOST="192.168.1.xxx"'
    echo '  U5G_USER="user_name"'
    exit 1
fi

# shellcheck source=/dev/null
. "$ENV_FILE"

# Validate required config
if [ -z "$U5G_HOST" ] || [ -z "$U5G_USER" ]; then
    echo "ERROR: U5G_HOST and U5G_USER must be set in $ENV_FILE"
    exit 1
fi

HOST="$U5G_HOST"

usage() {
    echo "Usage: carrier [auto|att|tmobile|verizon|status] [host]"
    echo "  auto     - Let Roamless pick the best network"
    echo "  att      - Force AT&T (310410)"
    echo "  tmobile  - Force T-Mobile (310260)"
    echo "  verizon  - Force Verizon (311480)"
    echo "  status   - Show current carrier"
    echo ""
    echo "  Optional: specify host as second argument (default: $HOST)"
    exit 1
}

# Optional host override
[ -n "$2" ] && HOST="$2"

# Resolve the AT+COPS command for the requested carrier
COPS_CMD=""
case "$1" in
    auto)    COPS_CMD='AT+COPS=0' ;;
    att)     COPS_CMD='AT+COPS=1,2,\"310410\",7' ;;
    tmobile) COPS_CMD='AT+COPS=1,2,\"310260\",7' ;;
    verizon) COPS_CMD='AT+COPS=1,2,\"311480\",7' ;;
    status)  ssh "${U5G_USER}@${HOST}" 'atcli -o'; exit $? ;;
    *)       usage ;;
esac

# Switch carrier, wait for the modem to settle, then report the active network.
# COPS_CMD is set by this script (not user input), so client-side expansion is intended.
# shellcheck disable=SC2029
ssh "${U5G_USER}@${HOST}" "atcli -t 60 -A \"$COPS_CMD\" && sleep 3 && atcli -o"
