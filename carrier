#!/bin/sh

# Load env file from same directory as script
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="$SCRIPT_DIR/.env"

if [ ! -f "$ENV_FILE" ]; then
    echo "ERROR: .env file not found at $ENV_FILE"
    echo "Create it with:"
    echo '  U5G_HOST="192.168.1.xxx"'
    echo '  U5G_USER="user_name"'
    exit 1
fi

# shellcheck source=/dev/null
. "$ENV_FILE"

# Validate required config
if [ -z "$U5G_HOST" ] || [ -z "$U5G_USER" ]; then
    echo "ERROR: U5G_HOST and U5G_USER must be set in $ENV_FILE"
    exit 1
fi

HOST="$U5G_HOST"

usage() {
    echo "Usage: carrier [auto|att|tmobile|verizon|status|signal|info] [host]"
    echo "  auto     - Let Roamless pick the best network"
    echo "  att      - Force AT&T (310410)"
    echo "  tmobile  - Force T-Mobile (310260)"
    echo "  verizon  - Force Verizon (311480)"
    echo "  status   - Show current carrier"
    echo "  signal   - Show current signal strength"
    echo "  info     - Show carrier status and signal together"
    echo ""
    echo "  Optional: specify host as second argument (default: $HOST)"
    exit 1
}

# Optional host override
[ -n "$2" ] && HOST="$2"

# Map a numeric MNC to a human-readable carrier name
carrier_name() {
    case "$1" in
        310410) echo "AT&T" ;;
        310260) echo "T-Mobile" ;;
        311480) echo "Verizon" ;;
        *)      echo "Unknown carrier" ;;
    esac
}

# Fetch the current carrier and annotate the numeric code with its name
show_status() {
    output="$(ssh "${U5G_USER}@${HOST}" 'atcli -o')"
    rc=$?
    [ $rc -ne 0 ] && { printf '%s\n' "$output"; return $rc; }

    # Pull the first 6-digit MNC out of the output and label it
    mnc="$(printf '%s' "$output" | grep -oE '3[0-9]{5}' | head -n 1)"
    if [ -n "$mnc" ]; then
        echo "Carrier: $(carrier_name "$mnc") ($mnc)"
    else
        printf '%s\n' "$output"
    fi
}

# Fetch and display signal info.
# The QMI device path (qrtr://3) is specific to the U5G's modem and may differ
# across firmware/modem revisions. If `signal` stops working, re-check this path
# on the device (e.g. `ls /dev/qcqmi*` or `qmicli -L`).
show_signal() {
    output="$(ssh "${U5G_USER}@${HOST}" 'qmicli -d qrtr://3 --nas-get-signal-info')"
    rc=$?
    printf '%s\n' "$output"
    return $rc
}

# Show carrier status and signal together
show_info() {
    show_status
    echo ""
    show_signal
}

# Resolve the AT+COPS command for the requested carrier
COPS_CMD=""
case "$1" in
    auto)    COPS_CMD='AT+COPS=0' ;;
    att)     COPS_CMD='AT+COPS=1,2,\"310410\",7' ;;
    tmobile) COPS_CMD='AT+COPS=1,2,\"310260\",7' ;;
    verizon) COPS_CMD='AT+COPS=1,2,\"311480\",7' ;;
    status)  show_status; exit $? ;;
    signal)  show_signal; exit $? ;;
    info)    show_info;   exit $? ;;
    *)       usage ;;
esac

# Switch carrier, wait for the modem to settle, then report the active network.
# COPS_CMD is set by this script (not user input), so client-side expansion is intended.
# shellcheck disable=SC2029
ssh "${U5G_USER}@${HOST}" "atcli -t 60 -A \"$COPS_CMD\" && sleep 3" || exit $?
show_info